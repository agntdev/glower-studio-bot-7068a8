[
  {
    "name": "/start replies with the welcome + main menu",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "👋 Welcome to GlowEr Beauty Studio! Tap a button below to get started." }
          }
        ]
      }
    ]
  },
  {
    "name": "Back to menu re-renders welcome",
    "steps": [
      {
        "send": { "callback": "menu:main" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "👋 Welcome to GlowEr Beauty Studio! Tap a button below to get started." }
          }
        ]
      }
    ]
  }
]
