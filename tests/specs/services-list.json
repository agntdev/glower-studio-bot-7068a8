[
  {
    "name": "Browse Services shows empty state",
    "steps": [
      {
        "send": { "callback": "services:list" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "No services available yet — check back soon!"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Help menu button shows help text",
    "steps": [
      {
        "send": { "callback": "menu:help" },
        "expect": [{ "method": "editMessageText" }]
      }
    ]
  }
]
